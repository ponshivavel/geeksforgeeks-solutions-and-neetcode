class Solution {
    public boolean isSubsequence(String s, String t) {
      
        StringBuilder sd = new StringBuilder();
        
        int i =0;int j =0;
        while(i<s.length() && j<t.length()){
            if(s.charAt(i)==t.charAt(j)){
                sd.append(t.charAt(j));
                j++; i++; 
            }
             else{
                j++;
            }
      
        }
        if(s.length()==sd.length()) {return true;}
        else return false;

    }
}
