class Solution {
    public int findMaxConsecutiveOnes(int[] arr) {
        int count =arr[0];
        int max =0;
        if(arr.length<2) return arr[0];

        for(int i =0;i<arr.length-1;i++){
            if(arr[i]==arr[i+1]){
                   count+=arr[i+1];
            }
             
            else{
                
                count=arr[i+1];
            }max= Math.max(count,max);
           
        }
return max;
        
    }
}
